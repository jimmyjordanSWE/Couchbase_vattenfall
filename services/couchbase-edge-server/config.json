{
  "interface": "0.0.0.0:59840",
  "enable_anonymous_users": true,
  "databases": {
    "main": {
      "path": "/tmp/main.cblite2",
      "create": true,
      "enable_client_sync": "bidirectional",
      "enable_client_writes": true,
      "collections": ["central.data"]
    }
  },
  "replications": [
    {
      "source": "${SYNC_GATEWAY_URL}",
      "target": "main",
      "bidirectional": true,
      "continuous": true,
      "collections": {
        "central.data": {}
      }
    }
  ],
  "logging": {
    "console": {
      "enabled": true,
      "log_level": "info"
    }
  }
}
