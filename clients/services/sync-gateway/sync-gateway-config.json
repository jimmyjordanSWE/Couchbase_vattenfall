{
  "bootstrap": {
    "server": "couchbase://${COUCHBASE_SERVER}",
    "username": "${COUCHBASE_USERNAME}",
    "password": "${COUCHBASE_PASSWORD}",
    "use_tls_server": false
  },
  "api": {
    "public_interface": ":4984",
    "admin_interface": ":4985"
  },
  "logging": {
    "console": {
      "enabled": true,
      "log_level": "info",
      "log_keys": ["*"]
    }
  }
}
