{
  "name": "edge-runtime-mvp",
  "description": "Ordered module startup for simulator -> edge app pipeline",
  "log_file": "../logs/pipeline.jsonl",
  "modules": [
    {
      "id": "02-edge-app",
      "cwd": "02-edge-app",
      "command": "node",
      "args": ["dist/index.js"],
      "enabled": true,
      "info": "TypeScript edge API (ingest + persistence)",
      "endpoints": [
        "GET http://127.0.0.1:3000/health",
        "GET http://127.0.0.1:3000/status",
        "POST http://127.0.0.1:3000/ingest",
        "GET http://127.0.0.1:3000/events/recent"
      ],
      "status_endpoint": "http://127.0.0.1:3000/status",
      "wait_for_http": "http://127.0.0.1:3000/health",
      "wait_timeout_ms": 30000,
      "start_delay_ms": 1000,
      "env": {
        "PORT": "3000",
        "CB_CONN_STR": "couchbase://127.0.0.1",
        "CB_USERNAME": "Administrator",
        "CB_PASSWORD": "vattenfall",
        "CB_BUCKET": "edge_events",
        "NODE_ENV": "development"
      }
    },
    {
      "id": "01-simulator",
      "cwd": "01-simulator",
      "command": "node",
      "args": [
        "generate_turbine_data.js",
        "--realtime",
        "true",
        "--cadence-ms",
        "500",
        "--turbines",
        "1",
        "--fault-mode",
        "mixed",
        "--console-mode",
        "silent",
        "--ingest-url",
        "http://127.0.0.1:3000/ingest"
      ],
      "enabled": true,
      "info": "Real-time turbine simulator (posts to ingest)",
      "endpoints": [
        "POST target: http://127.0.0.1:3000/ingest"
      ],
      "start_delay_ms": 0
    }
  ]
}
